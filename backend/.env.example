# ────────────────────────────────────────────────
# SmartTax Germany — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ────────────────────────────────────────────────

# Application
APP_NAME="SmartTax Germany"
DEBUG=false

# Database
# Development: SQLite (no setup needed)
DATABASE_URL=sqlite:///./smarttax.db
# Production (PostgreSQL on e.g. Supabase/Railway):
# DATABASE_URL=postgresql://user:password@host:5432/smarttax

# Admin Panel — Change these BEFORE first run in production!
ADMIN_PASSWORD=changeme_admin_password_here
ADMIN_SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Ollama (AI features) — leave as-is for local Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_ENABLED=true
# Timeout in seconds for Ollama requests
OLLAMA_TIMEOUT=30
